server_address = "vpn.nwafu.edu.cn"
server_port = 443
username = "student_id"
password = "password"
totp_secret = "" # Base32 secret for LDAP secondary TOTP authentication
disable_remote_dns = false
socks_bind = ":1080"
socks_user = ""
socks_passwd = ""
http_bind = ":1081"
shadowsocks_url = "" # "ss://aes-128-gcm:password@:1082"
dial_direct_proxy = "" # "http://127.0.0.1:7890" or "socks://127.0.0.1:7890"
tcp_tunnel_mode = false
tun_mode = false
add_route = false
dns_ttl = 3600
disable_keep_alive = false
keep_alive_url = "" # "https://www.cnki.net/favicon.ico"
remote_dns_server = "auto"
secondary_dns_server = "114.114.114.114"
dns_server_bind = ""
dns_hijack = false
fake_ip = false
debug_dump = false

# Port forwarding
port_forwarding = [
#    { network_type = "tcp", bind_address = "127.0.0.1:9898", remote_address = "10.10.98.98:80" },
#    { network_type = "tcp", bind_address = "127.0.0.1:9899", remote_address = "10.10.98.98:80" },
#    { network_type = "udp", bind_address = "127.0.0.1:1053", remote_address = "10.10.0.21:53" }
]

custom_dns = [
#    { host_name = "library.nwafu.edu.cn", ip = "10.0.0.10"}
#    { host_name = "example.nwafu.edu.cn", ip = "10.0.0.11"}
]

# aTrust authentication settings
auth_type = "auth/psw" # LDAP: auth/psw; SMS: auth/smsCheckCode; enterprise WeChat: auth/qywechat
login_domain = "LDAP" # SMS uses sms73926; enterprise WeChat uses wechat
client_data_file = "client_data.json"
graph_code_file = "" # Optional: captcha image will open in browser if this left empty. If set, the program will save the captcha image to this file and ask user to input the code in terminal.
qywechat_qrcode_file = "qywechat_qrcode.png" # Relative paths are saved in the current working directory; empty disables saving.
qywechat_qrcode_terminal = true
qywechat_qrcode_browser = true
phone = ""
update_best_nodes_interval = 300
sid = ""
device_id = ""
sign_key = ""
resource_file = ""